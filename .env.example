# Vercel Environment Variables
# Set these in your Vercel project dashboard — never commit real values

# ── Default LLM (powers the app for users who don't bring their own key) ──
# Groq free tier — https://console.groq.com  (14 400 req/day free)
# Model used: llama-3.3-70b-versatile
GROQ_API_KEY=gsk_your_groq_key_here

# ── Job data sources (server-side, never exposed to browser) ──
# JSearch via RapidAPI — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here

# Adzuna — https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ── Anonymous metrics (optional) ──
# Supabase free tier — create one table called "events"
# Schema: id, event_name, session_id, metadata (jsonb), created_at
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─────────────────────────────────────────────────────────────────────────────
# DO NOT put user Anthropic/OpenAI keys here.
# Those are entered voluntarily in the Settings panel at runtime and stored
# only in the user's browser sessionStorage — never on our servers.
# ─────────────────────────────────────────────────────────────────────────────
